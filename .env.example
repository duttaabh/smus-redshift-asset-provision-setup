# SMUS Redshift Setup — Environment Configuration
# Copy this file to .env and edit for your environment:
#   cp .env.example .env

# AWS
# AWS_PROFILE=my-profile    # Uncomment to use a named AWS CLI profile
REGION=us-east-1

# Redshift cluster
CLUSTER_ID=my-redshift-cluster
REDSHIFT_HOST=my-redshift-cluster.xxxxxxxxxxxx.us-east-1.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=dev
REDSHIFT_USER=awsuser
REDSHIFT_PASSWORD='YourSecurePassword'

# DataZone / SMUS
DOMAIN_ID=dzd-xxxxxxxxxx
ADMIN_PROJECT_ID=xxxxxxxxxx
ADMIN_ENV_ID=xxxxxxxxxx

# Subscriptions (for 07-subscribe-assets.sh)
# CONSUMER_PROJECT_ID: the DataZone project to subscribe
# SUBSCRIBE_TABLES: comma-separated list of table names to subscribe to
CONSUMER_PROJECT_ID=xxxxxxxxxx
SUBSCRIBE_TABLES="employees,departments"

# VPC / Network (auto-discovered from cluster if omitted)
# VPC_ID=vpc-xxxxxxxxxx
# SUBNET_ID=subnet-xxxxxxxxxx
# SMUS_SG=sg-xxxxxxxxxx
# REDSHIFT_SG=sg-xxxxxxxxxx

# --- IdC Integration (for 01-setup-idc-redshift.sh) ---
IDC_NAMESPACE=AWSIDC
IDC_ROLE_NAME=RedshiftIdCIntegrationRole
IDC_PS_NAME=RedshiftQueryAccess
# Group-to-user mappings: "GroupName:user@email,GroupName2:user2@email"
# Multiple users per group: "GroupName:user1@email;user2@email"
IDC_GROUPS="DataAnalysts:analyst@example.com,DataEngineers:engineer@example.com"
# Table-level grants: "Group:LEVEL:table1;table2" (use * for all tables)
IDC_GROUP_GRANTS="DataAnalysts:SELECT:employees,DataEngineers:ALL:*"

# --- TIP (Trusted Identity Propagation) (for 07-setup-tip-project.sh) ---
TIP_PROJECT_NAME=tip-redshift-project
TIP_PROFILE_NAME=SQL analytics
# Per-user grants: "idcUserId:LEVEL:table1;table2,..."
# Get IdC user IDs from: aws identitystore list-users --identity-store-id <id>
# TIP_USER_GRANTS="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:SELECT:departments,yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy:SELECT:employees"
